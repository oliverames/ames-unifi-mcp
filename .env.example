# UniFi MCP Server Configuration

# Controller URL (local Dream Machine or cloud)
UNIFI_HOST=https://192.168.1.1

# API Key (preferred — generate at Settings > Control Plane > Integrations)
UNIFI_API_KEY=

# Username/Password (fallback — session-based)
# UNIFI_USERNAME=
# UNIFI_PASSWORD=

# Site name (default: "default")
UNIFI_SITE=default

# SSL verification (default: true — set false for self-signed certs on local UDM)
UNIFI_VERIFY_SSL=true

# Tool registration mode: lazy (3 meta-tools) or eager (all tools)
UNIFI_TOOL_MODE=lazy

# Permission profile: read-only, standard, admin
UNIFI_PERMISSION_PROFILE=standard

# Log level: debug, info, warn, error
UNIFI_LOG_LEVEL=error
